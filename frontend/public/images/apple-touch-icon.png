<!-- Note: This should be a PNG file. Here's a template as SVG that can be converted: -->

<?xml version="1.0" encoding="UTF-8"?>
<svg 
  xmlns="http://www.w3.org/2000/svg" 
  viewBox="0 0 180 180" 
  width="180" 
  height="180"
>
  <!-- Round background -->
  <rect width="180" height="180" fill="#224c87" rx="40"/>
  
  <!-- "H" Logo -->
  <text 
    x="90" 
    y="100" 
    font-family="Montserrat, Arial, sans-serif" 
    font-size="100" 
    font-weight="bold" 
    fill="#ffffff" 
    text-anchor="middle"
    dominant-baseline="middle"
  >H</text>
  
  <!-- Decoration -->
  <rect x="20" y="20" width="140" height="140" fill="none" stroke="#da3832" stroke-width="3" rx="30"/>
</svg>